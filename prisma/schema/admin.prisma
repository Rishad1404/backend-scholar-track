enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  EXPIRED
  CANCELLED
}

model Admin {
  id           String @id @default(uuid())
  userId       String  @unique
  universityId String?

  name        String  @db.VarChar(255) 
  email       String  @db.VarChar(255) 
  profilePhoto String? @db.VarChar(500)
  isOwner     Boolean @default(false)
  phone       String? @db.VarChar(20)
  designation String? @db.VarChar(100)

  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id], onDelete: Restrict)
  subscriptionPayments SubscriptionPayment[]
  approvedDisbursements Disbursement[]

  @@index([isDeleted], name: "idx_admin_isDeleted")
  @@index([universityId], name: "idx_admin_universityId")
  @@index([email], name: "idx_admin_email")
  @@map("admins")
}