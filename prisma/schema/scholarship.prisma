enum ScholarshipStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  CANCELLED
}

model Scholarship {
  id               String            @id @default(uuid())
  universityId     String
  departmentId     String?
  levelId          String?
  title            String            @db.VarChar(255)
  description      String?           @db.Text
  deadline         DateTime
  totalAmount      Float             @db.DoublePrecision
  amountPerStudent Float             @db.DoublePrecision
  quota            Int               @db.Integer
  status           ScholarshipStatus @default(DRAFT)

  minGpa                Float?  @db.DoublePrecision
  minCgpa               Float?  @db.DoublePrecision
  financialNeedRequired Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Relations
  university       University     @relation(fields: [universityId], references: [id], onDelete: Cascade)
  department       Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  level            AcademicLevel? @relation(fields: [levelId], references: [id], onDelete: SetNull)
  applications     Application[]
  disbursements    Disbursement[]
  requiredDocTypes DocumentType[]

  @@index([isDeleted], name: "idx_scholarship_isDeleted")
  @@index([universityId], name: "idx_scholarship_universityId")
  @@index([status], name: "idx_scholarship_status")
  @@map("scholarships")
}
