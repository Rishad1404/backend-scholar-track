
enum DisbursementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Disbursement {
  id            String @id @default(uuid())
  applicationId String @unique 
  studentId     String 
  approvedById  String 
  universityId  String 
  scholarshipId String 

  amount   Float              @db.DoublePrecision
  currency String             @default("BDT") @db.VarChar(10)
  status   DisbursementStatus @default(PENDING)

  // Stripe Connect Fields
  stripeTransferId String? @unique 
  stripePayoutId   String? @unique 
  platformFee      Float?  @db.DoublePrecision
  metadata         Json?

  disbursedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  approvedBy  Admin       @relation(fields: [approvedById], references: [id], onDelete: Restrict)
  university  University  @relation(fields: [universityId], references: [id], onDelete: Restrict)
  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Restrict)

  @@index([studentId], name: "idx_disbursement_studentId")
  @@index([universityId], name: "idx_disbursement_universityId")
  @@index([status], name: "idx_disbursement_status")
  @@map("disbursements")
}