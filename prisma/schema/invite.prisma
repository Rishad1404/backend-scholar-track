enum InviteRole {
  DEPARTMENT_HEAD
  COMMITTEE_REVIEWER
}

model Invite {
  id              String @id @default(uuid())
  universityId    String 
  invitedByUserId String  

  email String @db.VarChar(255)
  role  InviteRole

  // For DEPARTMENT_HEAD invites — which department they're assigned to
  departmentId String? 

  token     String   @unique 
  used      Boolean  @default(false)
  expiresAt DateTime // invite expires (e.g. 7 days)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Relations
  university University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  invitedBy  User        @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([email], name: "idx_invite_email")
  @@index([token], name: "idx_invite_token")
  @@index([universityId], name: "idx_invite_universityId")
  @@index([isDeleted], name: "idx_invite_isDeleted")
  @@map("invites")
}
