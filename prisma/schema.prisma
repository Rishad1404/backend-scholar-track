generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AcademicLevel {
  id   String @id @default(uuid(7))
  name String @unique @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([isDeleted], name: "idx_academic_level_isDeleted")
  @@index([name], name: "idx_academic_level_name")
  @@map("academic_levels")
}

model AcademicTerm {
  id   String @id @default(uuid(7))
  name String @unique @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([isDeleted], name: "idx_academic_term_isDeleted")
  @@index([name], name: "idx_academic_term_name")
  @@map("academic_terms")
}
